<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Sorteador Bingo Interativo - Potenciação</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; display: flex; height: 100vh; margin: 0; background: #121212; color: white; overflow: hidden; }
        
        /* Área Principal */
        .main { flex: 3; display: flex; flex-direction: column; align-items: center; justify-content: center; border-right: 1px solid #444; padding: 20px; }
        h1 { color: #f1c40f; letter-spacing: 2px; margin-bottom: 5px; }
        .sub { color: #888; margin-bottom: 30px; }
        .display-operacao { font-size: 180px; font-weight: bold; margin: 40px; color: #ffffff; text-shadow: 0 0 20px rgba(255,255,255,0.2); height: 220px; display: flex; align-items: center; }
        
        /* Lateral de Histórico */
        .sidebar { flex: 1; padding: 20px; overflow-y: auto; background: #1e1e1e; }
        .sidebar h2 { font-size: 18px; border-bottom: 2px solid #444; padding-bottom: 10px; color: #bbb; text-align: center; }
        .historico-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        
        /* Itens do Histórico (Clicáveis) */
        .historico-item { 
            background: #2d2d2d; padding: 10px; border-radius: 4px; 
            text-align: center; font-size: 24px; color: #f1c40f; border: 1px solid #444;
            cursor: pointer; transition: 0.2s;
            animation: fadeIn 0.3s ease;
        }
        .historico-item:hover { background: #3d3d3d; transform: scale(1.05); border-color: #f1c40f; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Botões */
        .controls { display: flex; flex-direction: column; gap: 15px; align-items: center; }
        button { padding: 20px 60px; font-size: 24px; cursor: pointer; background: #f1c40f; color: #000; border: none; border-radius: 50px; font-weight: bold; transition: 0.2s; box-shadow: 0 4px #d4ac0d; }
        button:hover { background: #d4ac0d; }
        button:active { transform: translateY(2px); box-shadow: 0 2px #d4ac0d; }
        button:disabled { background: #444; color: #888; box-shadow: none; cursor: not-allowed; }
        
        .reset { background: transparent; color: #e74c3c; font-size: 14px; border: 1px solid #e74c3c; padding: 8px 15px; border-radius: 4px; margin-top: 30px; box-shadow: none; font-weight: normal; }
        .reset:hover { background: #e74c3c; color: white; }

        /* Quadro de Resultado (Modal) */
        .modal-overlay { 
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.85); backdrop-filter: blur(5px);
            justify-content: center; align-items: center; z-index: 1000;
            opacity: 0; transition: opacity 0.3s ease;
        }
        .modal-overlay.show { display: flex; opacity: 1; }
        .modal-content { 
            background: #2c3e50; padding: 50px; border-radius: 20px; border: 4px solid #f1c40f;
            text-align: center; box-shadow: 0 10px 50px rgba(0,0,0,0.5);
            transform: scale(0.8); transition: transform 0.3s ease;
        }
        .modal-overlay.show .modal-content { transform: scale(1); }
        .modal-op { font-size: 100px; color: #bdc3c7; margin-bottom: 10px; font-weight: bold; }
        .modal-res { font-size: 160px; color: #f1c40f; font-weight: bold; text-shadow: 0 0 30px rgba(241,196,15,0.4); }
        .close-modal { margin-top: 30px; background: #95a5a6; font-size: 18px; padding: 10px 30px; }

    </style>
</head>
<body>

    <div class="main">
        <h1>BINGO: POTÊNCIAS</h1>
        <p class="sub">Bases e Expoentes de 1 a 6</p>
        <div id="operacao-atual" class="display-operacao">?</div>
        
        <div class="controls">
            <button id="btn-sortear" onclick="sortear()">PRÓXIMA OPERAÇÃO</button>
            <button class="reset" onclick="zerarSorteador()">Zerar Sorteador</button>
        </div>
    </div>

    <div class="sidebar">
        <h2>HISTÓRICO (Clique p/ ver resultado)</h2>
        <div id="historico" class="historico-grid"></div>
    </div>

    <div id="modal" class="modal-overlay" onclick="fecharResultado()">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div id="modal-op" class="modal-op"></div>
            <div>é igual a</div>
            <div id="modal-res" class="modal-res"></div>
            <button class="close-modal" onclick="fecharResultado()">Fechar</button>
        </div>
    </div>

    <script>
        let operacoesPool = [];

        function inicializar() {
            operacoesPool = [];
            for (let b = 1; b <= 6; b++) {
                for (let e = 1; e <= 6; e++) {
                    // Armazena a estrutura da operação e o resultado calculado
                    operacoesPool.push({
                        html: b + '<sup>' + e + '</sup>',
                        resultado: Math.pow(b, e).toLocaleString('pt-BR')
                    });
                }
            }
            embaralhar();
        }

        function embaralhar() {
            operacoesPool.sort(() => Math.random() - 0.5);
        }

        function sortear() {
            if (operacoesPool.length === 0) {
                document.getElementById('operacao-atual').style.fontSize = '80px';
                document.getElementById('operacao-atual').innerText = "FIM!";
                document.getElementById('btn-sortear').disabled = true;
                return;
            }

            // Pega a última operação do pool embaralhado
            const itemSorteado = operacoesPool.pop();

            // Atualiza o destaque central
            document.getElementById('operacao-atual').innerHTML = itemSorteado.html;

            // Adiciona ao histórico lateral como um elemento clicável
            const historicoDiv = document.getElementById('historico');
            const novoItem = document.createElement('div');
            novoItem.className = 'historico-item';
            novoItem.innerHTML = itemSorteado.html;
            
            // Define o que acontece ao clicar no item do histórico
            novoItem.onclick = function() {
                mostrarResultado(itemSorteado.html, itemSorteado.resultado);
            };

            historicoDiv.prepend(novoItem);
        }

        // Funções do Modal de Resultado
        function mostrarResultado(opHtml, resText) {
            document.getElementById('modal-op').innerHTML = opHtml;
            document.getElementById('modal-res').innerText = resText;
            document.getElementById('modal').classList.add('show');
        }

        function fecharResultado() {
            document.getElementById('modal').classList.remove('show');
        }

        // Função para zerar tudo
        function zerarSorteador() {
            if (confirm("Tem certeza que deseja zerar o jogo atual?")) {
                fecharResultado();
                document.getElementById('historico').innerHTML = "";
                document.getElementById('operacao-atual').innerHTML = "?";
                document.getElementById('operacao-atual').style.fontSize = '180px';
                document.getElementById('btn-sortear').disabled = false;
                inicializar();
            }
        }

        // Inicia o sistema
        inicializar();
    </script>
</body>
</html>
